# 宥爵智能科技 — 官網後端環境變數
# YouJue Website Backend Environment Variables

# ---- 環境 ----
ENVIRONMENT=development

# ---- CORS ----
# 額外允許的前端域名（逗號分隔）
ALLOWED_ORIGINS=

# ---- Email 通知 (Resend) ----
RESEND_API_KEY=
FROM_EMAIL=YouJue Website <noreply@youjue.ai>
NOTIFY_EMAIL=jennie@youjue.ai

# ---- Sentry 錯誤追蹤 ----
SENTRY_DSN=
